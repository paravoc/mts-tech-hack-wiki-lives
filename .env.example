# MWS Tables
MWS_TOKEN=replace_with_mws_token
MWS_TABLE_ID=replace_with_source_table_id
MWS_VIEW_ID=replace_with_source_view_id

# Wiki pages storage
WIKI_PAGES_TABLE_ID=replace_with_wiki_pages_table_id
WIKI_PAGES_VIEW_ID=replace_with_wiki_pages_view_id

# Server
HTTP_PORT=3000
LOG_LEVEL=info

# Cache
CACHE_TTL_SECONDS=60

# Reliability
REQUEST_TIMEOUT_MS=10000
RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_MS=1000
WS_HEARTBEAT_SECONDS=20

# Features
ENABLE_WEBSOCKET=true
ENABLE_AI=false

# AI provider
AI_PROVIDER=none
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=
AI_MAX_TOKENS=500
AI_TEMPERATURE=0.2
